# LinkedIn OAuth
# Set in: Netlify UI → Site settings → Environment variables
LINKEDIN_CLIENT_ID=your_linkedin_app_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_app_client_secret
LINKEDIN_OAUTH_STATE_SECRET=generate_with_openssl_rand_hex_32
LINKEDIN_PUBLISH_SECRET=generate_with_openssl_rand_hex_32

# AI Content Generation
# Set in: Netlify UI (for functions) + GitHub Secrets (for Actions)
GITHUB_TOKEN=your_github_token_for_models_api
