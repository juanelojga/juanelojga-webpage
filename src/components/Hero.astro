---
import { Image } from 'astro:assets';
import { useTranslations } from '../utils/translate';

const t = useTranslations(Astro);
---

<header class="relative w-full overflow-hidden bg-background-light px-6 py-24 lg:py-36" id="home">
  <!-- SVG Neural Network Background -->
  <svg
    class="pointer-events-none absolute inset-0 hidden size-full lg:block"
    viewBox="0 0 1200 800"
    preserveAspectRatio="xMidYMid slice"
    aria-hidden="true"
  >
    <defs>
      <radialGradient id="node-glow">
        <stop offset="0%" stop-color="var(--color-primary, #10b981)" stop-opacity="0.6"></stop>
        <stop offset="100%" stop-color="var(--color-primary, #10b981)" stop-opacity="0"></stop>
      </radialGradient>
    </defs>

    <!-- Connecting lines with flowing dash animation -->
    <path d="M100,200 L350,350" class="neural-line dash-flow" pathLength="1"></path>
    <path d="M350,350 L600,180" class="neural-line dash-flow flow-delay-1" pathLength="1"></path>
    <path d="M600,180 L850,300" class="neural-line dash-flow flow-delay-2" pathLength="1"></path>
    <path d="M850,300 L1050,150" class="neural-line dash-flow flow-delay-3" pathLength="1"></path>
    <path d="M200,550 L500,500" class="neural-line dash-flow flow-delay-1" pathLength="1"></path>
    <path d="M500,500 L750,600" class="neural-line dash-flow flow-delay-2" pathLength="1"></path>
    <path d="M750,600 L1000,450" class="neural-line dash-flow flow-delay-3" pathLength="1"></path>
    <path d="M350,350 L500,500" class="neural-line dash-flow flow-delay-2" pathLength="1"></path>
    <path d="M600,180 L750,600" class="neural-line dash-flow flow-delay-3" pathLength="1"></path>
    <path d="M850,300 L1000,450" class="neural-line dash-flow" pathLength="1"></path>

    <!-- Traveling data pulse particles -->
    <circle r="3" class="data-pulse">
      <animateMotion
        dur="3s"
        repeatCount="indefinite"
        path="M100,200 L350,350 L600,180 L850,300 L1050,150"></animateMotion>
    </circle>
    <circle r="2.5" class="data-pulse pulse-delay-1">
      <animateMotion dur="4s" repeatCount="indefinite" path="M200,550 L500,500 L750,600 L1000,450"
      ></animateMotion>
    </circle>
    <circle r="2" class="data-pulse pulse-delay-2">
      <animateMotion dur="3.5s" repeatCount="indefinite" path="M350,350 L500,500 L750,600"
      ></animateMotion>
    </circle>
    <circle r="2.5" class="data-pulse pulse-delay-3">
      <animateMotion dur="5s" repeatCount="indefinite" path="M600,180 L750,600 L1000,450 L850,300"
      ></animateMotion>
    </circle>

    <!-- Node glow rings -->
    <circle cx="350" cy="350" r="14" class="node-ring ring-delay-0"></circle>
    <circle cx="600" cy="180" r="14" class="node-ring ring-delay-1"></circle>
    <circle cx="850" cy="300" r="14" class="node-ring ring-delay-2"></circle>
    <circle cx="500" cy="500" r="12" class="node-ring ring-delay-3"></circle>
    <circle cx="1000" cy="450" r="12" class="node-ring ring-delay-1"></circle>

    <!-- Nodes (sparser left, denser right) -->
    <circle cx="100" cy="200" r="4" class="neural-node float-slow"></circle>
    <circle cx="200" cy="550" r="3" class="neural-node float-medium"></circle>
    <circle cx="350" cy="350" r="5" class="neural-node pulse-node float-slow"></circle>
    <circle cx="500" cy="500" r="3.5" class="neural-node float-medium"></circle>
    <circle cx="600" cy="180" r="4.5" class="neural-node pulse-node float-slow"></circle>
    <circle cx="750" cy="600" r="4" class="neural-node float-medium"></circle>
    <circle cx="850" cy="300" r="5" class="neural-node pulse-node float-slow"></circle>
    <circle cx="950" cy="700" r="3" class="neural-node float-medium"></circle>
    <circle cx="1000" cy="450" r="4.5" class="neural-node float-slow"></circle>
    <circle cx="1050" cy="150" r="3.5" class="neural-node pulse-node float-medium"></circle>
    <circle cx="1100" cy="550" r="4" class="neural-node float-slow"></circle>
    <circle cx="700" cy="100" r="3" class="neural-node float-medium"></circle>
    <circle cx="900" cy="650" r="3.5" class="neural-node pulse-node float-slow"></circle>
  </svg>

  <div
    class="relative z-10 mx-auto flex w-full max-w-6xl flex-col-reverse items-center gap-12 lg:flex-row lg:justify-between"
  >
    <!-- Left Side: Text -->
    <div class="text-center lg:w-1/2 lg:text-left">
      <span
        class="hero-stagger-1 mb-4 inline-block rounded-full bg-primary/10 px-4 py-1.5 font-mono text-xs font-bold uppercase tracking-widest text-primary"
      >
        {t('hero.subtitleTag')}
      </span>

      <h1
        class="hero-stagger-2 mb-6 text-4xl font-extrabold leading-tight tracking-tight text-slate-900 md:text-5xl lg:text-6xl"
      >
        {t('hero.headline')}
      </h1>

      <p class="hero-stagger-3 mb-8 max-w-xl text-base leading-relaxed text-slate-600 md:text-lg">
        {t('hero.description')}
      </p>

      <div class="hero-stagger-4 flex flex-wrap justify-center gap-4 lg:justify-start">
        <a
          href="#contact"
          class="rounded-lg bg-primary px-6 py-3 font-semibold text-white shadow-lg transition-all duration-200 hover:-translate-y-0.5 hover:bg-primary/90 hover:shadow-xl"
        >
          {t('hero.ctaPrimary')}
        </a>
        <a
          href="#projects"
          class="rounded-lg border border-slate-300 bg-white px-6 py-3 font-semibold text-slate-700 transition-all duration-200 hover:-translate-y-0.5 hover:border-primary hover:text-primary hover:shadow-xl"
        >
          {t('hero.ctaSecondary')}
        </a>
      </div>
    </div>

    <!-- Right Side: Image -->
    <div class="hero-stagger-image flex justify-center lg:w-1/2 lg:justify-end">
      <div class="relative">
        <div
          class="absolute -inset-4 rounded-2xl bg-gradient-to-br from-primary/20 to-primary/5 blur-2xl"
        >
        </div>
        <Image
          src="/me.jpg"
          alt="Portrait of Juan Almeida"
          width={320}
          height={480}
          class="relative rounded-2xl object-cover shadow-xl transition-transform duration-500 hover:scale-[1.02]"
          loading="eager"
        />
      </div>
    </div>
  </div>
</header>

<style>
  /* Neural network SVG styles */
  .neural-node {
    fill: var(--color-primary, #10b981);
    opacity: 0.25;
  }

  .neural-line {
    stroke: var(--color-primary, #10b981);
    stroke-width: 1.5;
    fill: none;
    opacity: 0.18;
  }

  /* Flowing dash animation on lines */
  .dash-flow {
    stroke-dasharray: 0.08 0.06;
    animation: dash-scroll 4s linear infinite;
  }

  .flow-delay-1 {
    animation-delay: -1s;
  }

  .flow-delay-2 {
    animation-delay: -2s;
  }

  .flow-delay-3 {
    animation-delay: -3s;
  }

  @keyframes dash-scroll {
    to {
      stroke-dashoffset: -1;
    }
  }

  /* Traveling data pulse particles */
  .data-pulse {
    fill: var(--color-primary, #10b981);
    opacity: 0.5;
    filter: url(#node-glow);
  }

  .pulse-delay-1 {
    opacity: 0.4;
  }

  .pulse-delay-2 {
    opacity: 0.35;
  }

  .pulse-delay-3 {
    opacity: 0.45;
  }

  /* Node glow rings */
  .node-ring {
    fill: none;
    stroke: var(--color-primary, #10b981);
    stroke-width: 1;
    opacity: 0;
    animation: ring-ping 3s ease-out infinite;
  }

  .ring-delay-0 {
    animation-delay: 0s;
  }

  .ring-delay-1 {
    animation-delay: 0.8s;
  }

  .ring-delay-2 {
    animation-delay: 1.6s;
  }

  .ring-delay-3 {
    animation-delay: 2.4s;
  }

  @keyframes ring-ping {
    0% {
      r: 5;
      opacity: 0.35;
      stroke-width: 2;
    }
    100% {
      r: 22;
      opacity: 0;
      stroke-width: 0.5;
    }
  }

  /* Floating animations for nodes */
  .float-slow {
    animation: float-slow 8s ease-in-out infinite;
  }

  .float-medium {
    animation: float-medium 6s ease-in-out infinite;
  }

  /* Pulse animation for select nodes */
  .pulse-node {
    animation:
      pulse-node 4s ease-in-out infinite,
      float-slow 8s ease-in-out infinite;
  }

  @keyframes float-slow {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-15px);
    }
  }

  @keyframes float-medium {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(10px);
    }
  }

  @keyframes pulse-node {
    0%,
    100% {
      opacity: 0.25;
    }
    50% {
      opacity: 0.5;
    }
  }

  /* Entrance animations */
  @keyframes fade-in-up {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fade-in-scale {
    from {
      opacity: 0;
      transform: scale(0.95);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  .hero-stagger-1 {
    animation: fade-in-up 0.7s ease-out 0.1s both;
  }

  .hero-stagger-2 {
    animation: fade-in-up 0.7s ease-out 0.25s both;
  }

  .hero-stagger-3 {
    animation: fade-in-up 0.7s ease-out 0.4s both;
  }

  .hero-stagger-4 {
    animation: fade-in-up 0.7s ease-out 0.55s both;
  }

  .hero-stagger-image {
    animation: fade-in-scale 0.8s ease-out 0.3s both;
  }

  /* Respect reduced motion preferences */
  @media (prefers-reduced-motion: reduce) {
    .float-slow,
    .float-medium,
    .pulse-node,
    .dash-flow,
    .node-ring {
      animation: none;
    }

    .data-pulse,
    .data-pulse > animateMotion {
      display: none;
    }

    .hero-stagger-1,
    .hero-stagger-2,
    .hero-stagger-3,
    .hero-stagger-4,
    .hero-stagger-image {
      animation: none;
    }
  }
</style>
