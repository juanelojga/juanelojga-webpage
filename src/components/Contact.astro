---
import { useTranslations } from '../utils/translate';
const t = useTranslations(Astro);
---

<section id="contact" class="bg-background-light py-20 text-slate-900 lg:py-28">
  <div class="container mx-auto max-w-3xl px-6 text-center">
    <!-- Title -->
    <h2 class="mb-4 text-4xl font-extrabold text-slate-900 sm:text-5xl">
      {t('contact.title')}
    </h2>

    <!-- Subtitle -->
    <p class="mb-12 text-lg text-slate-600">
      {t('contact.subtitle')}
    </p>

    <!-- Social Icons -->
    <div class="mb-8 flex justify-center gap-8 text-3xl">
      <a
        href="https://github.com/juanelojga"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="GitHub"
        class="text-slate-600 transition hover:text-primary"
      >
        <i class="fa-brands fa-github"></i>
      </a>

      <a
        href="https://www.linkedin.com/in/juan-almeida-03806367/"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="LinkedIn"
        class="text-slate-600 transition hover:text-primary"
      >
        <i class="fa-brands fa-linkedin"></i>
      </a>

      <a
        href="https://www.instagram.com/juanelojga/"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Instagram"
        class="text-slate-600 transition hover:text-primary"
      >
        <i class="fa-brands fa-instagram"></i>
      </a>
    </div>

    <!-- Email with Copy -->
    <div class="flex items-center justify-center gap-3 text-slate-600">
      <span id="email-text">juanelojga@gmail.com</span>
      <button
        id="copy-email"
        aria-label={t('contact.copyEmailAria')}
        class="transition hover:text-primary"
      >
        <span class="material-symbols-outlined align-middle">content_copy</span>
      </button>
    </div>
  </div>

  <script is:inline>
    const copyBtn = document.getElementById('copy-email');
    const emailText = document.getElementById('email-text');

    copyBtn.addEventListener('click', async () => {
      await navigator.clipboard.writeText(emailText.textContent.trim());
      copyBtn.classList.add('text-primary');
      setTimeout(() => copyBtn.classList.remove('text-primary'), 1200);
    });
  </script>
</section>
