---
import { useTranslations } from '../utils/translate';
const t = useTranslations(Astro);
---

<footer class="border-t border-border bg-surface-secondary py-8">
  <div class="container mx-auto flex flex-col items-center gap-6 px-4">
    <!-- Logo -->
    <div class="flex items-center gap-2">
      <span class="material-symbols-outlined text-2xl text-signal-primary">terminal</span>
      <span class="font-semibold text-text-primary">Portfolio</span>
    </div>

    <!-- Social Links -->
    <nav class="flex items-center gap-6">
      <a
        href="https://linkedin.com/in/juanelojga"
        target="_blank"
        rel="me noopener noreferrer"
        class="rounded p-1 text-sm text-text-secondary transition-colors hover:text-signal-primary focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-signal-primary"
        >{t('footer.linkedin')}</a
      >
      <a
        href="https://github.com/juanelojga"
        target="_blank"
        rel="me noopener noreferrer"
        class="rounded p-1 text-sm text-text-secondary transition-colors hover:text-signal-primary focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-signal-primary"
        >{t('footer.github')}</a
      >
      <a
        href="https://twitter.com/juanelojga"
        target="_blank"
        rel="me noopener noreferrer"
        class="rounded p-1 text-sm text-text-secondary transition-colors hover:text-signal-primary focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-signal-primary"
        >{t('footer.twitter')}</a
      >
    </nav>

    <!-- Copyright -->
    <p class="text-sm text-text-secondary">
      &copy; {new Date().getFullYear()} Juan Almeida. {t('footer.rights')}
    </p>
  </div>
</footer>
