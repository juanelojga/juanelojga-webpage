---
import { useTranslations } from '../utils/translate';
const t = useTranslations(Astro);
---

<footer class="border-t border-slate-200 bg-slate-50 py-8">
  <div class="container mx-auto flex flex-col items-center gap-6 px-4">
    <!-- Logo -->
    <div class="flex items-center gap-2">
      <span class="material-symbols-outlined text-2xl text-primary">terminal</span>
      <span class="font-semibold text-slate-900">Portfolio</span>
    </div>

    <!-- Social Links -->
    <nav class="flex items-center gap-6">
      <a
        href="https://linkedin.com/in/juanelojga"
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm text-slate-500 transition-colors hover:text-primary"
        >{t('footer.linkedin')}</a
      >
      <a
        href="https://github.com/juanelojga"
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm text-slate-500 transition-colors hover:text-primary">{t('footer.github')}</a
      >
      <a
        href="https://twitter.com/juanelojga"
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm text-slate-500 transition-colors hover:text-primary">{t('footer.twitter')}</a
      >
    </nav>

    <!-- Copyright -->
    <p class="text-sm text-slate-400">
      &copy; {new Date().getFullYear()} Juan Almeida. {t('footer.rights')}
    </p>
  </div>
</footer>
