---
interface Props {
  language: string;
  code: string;
}

const { language, code } = Astro.props;
---

<div class="overflow-hidden rounded-xl bg-surface-tertiary">
  <div class="flex items-center gap-2 border-b border-border px-4 py-3">
    <span class="size-3 rounded-full bg-[#FF5F57]"></span>
    <span class="size-3 rounded-full bg-[#FEBC2E]"></span>
    <span class="size-3 rounded-full bg-[#28C840]"></span>
    <span class="ml-2 text-xs text-text-secondary">{language}</span>
  </div>
  <div class="overflow-x-auto p-4">
    <pre><code class="text-sm leading-relaxed text-text-primary">{code}</code></pre>
  </div>
</div>
