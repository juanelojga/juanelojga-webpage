---
import type { TocEntry } from '../../utils/blog';

interface Props {
  headings: TocEntry[];
  label: string;
}

const { headings, label } = Astro.props;
---

{
  headings.length > 0 && (
    <nav aria-label={label} class="toc">
      <h2 class="mb-3 font-mono text-xs font-bold uppercase tracking-wider text-text-secondary">
        {label}
      </h2>
      <ul class="space-y-1.5">
        {headings.map(h2 => (
          <li>
            <a
              href={`#${h2.slug}`}
              class="toc-link block rounded-sm px-2 py-1 font-mono text-sm text-text-secondary transition-colors hover:text-signal-primary"
              data-slug={h2.slug}
            >
              {h2.text}
            </a>
            {h2.children.length > 0 && (
              <ul class="ml-4 mt-1 space-y-1">
                {h2.children.map(h3 => (
                  <li>
                    <a
                      href={`#${h3.slug}`}
                      class="toc-link block rounded-sm px-2 py-1 font-mono text-xs text-text-secondary transition-colors hover:text-signal-primary"
                      data-slug={h3.slug}
                    >
                      {h3.text}
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))}
      </ul>
    </nav>
  )
}

<script>
  document.addEventListener('astro:page-load', () => {
    const tocLinks = document.querySelectorAll<HTMLAnchorElement>('.toc-link');
    if (tocLinks.length === 0) return;

    const headingElements: HTMLElement[] = [];
    tocLinks.forEach(link => {
      const slug = link.dataset.slug;
      if (slug) {
        const el = document.getElementById(slug);
        if (el) headingElements.push(el);
      }
    });

    const setActive = (slug: string) => {
      tocLinks.forEach(link => {
        if (link.dataset.slug === slug) {
          link.classList.add('text-signal-primary', 'bg-signal-primary/10');
          link.classList.remove('text-text-secondary');
        } else {
          link.classList.remove('text-signal-primary', 'bg-signal-primary/10');
          link.classList.add('text-text-secondary');
        }
      });
    };

    const observer = new IntersectionObserver(
      entries => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            setActive(entry.target.id);
            break;
          }
        }
      },
      { rootMargin: '-80px 0px -60% 0px', threshold: 0 }
    );

    headingElements.forEach(el => observer.observe(el));
  });
</script>
