---
import { useTranslations } from '../utils/translate';
import '../css/navbar.css';

const t = useTranslations(Astro);
const lang = Astro.currentLocale === 'es' ? 'es' : 'en';
---

<nav
  id="navbar"
  class="bg-surface-primary/90 sticky top-0 z-50 w-full backdrop-blur-xl transition-all duration-300"
>
  <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-3">
    <!-- Left: Logo -->
    <a
      href={`/${lang}/`}
      class="group flex items-center rounded font-mono text-sm no-underline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-signal-primary"
    >
      <span id="logo-typed" class="logo-typed" aria-hidden="true"></span>
      <span id="logo-cursor" class="logo-cursor-hidden ml-0.5 select-none text-signal-primary"
        >_</span
      >
      <span class="sr-only">&gt; juan.almeida</span>
    </a>

    <!-- Right: Hamburger Menu (Mobile) -->
    <div class="md:hidden">
      <button
        id="menu-toggle"
        aria-label="Open navigation menu"
        aria-controls="mobile-menu"
        aria-expanded="false"
        class="rounded-md p-2 text-text-secondary transition hover:text-text-primary focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-signal-primary"
      >
        <svg
          class="size-6"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16m-7 6h7"></path>
        </svg>
      </button>
    </div>

    <!-- Desktop Navigation -->
    <div class="hidden items-center gap-1 md:flex">
      <a
        href={`/${lang}/blog/`}
        class="ml-4 rounded-lg px-4 py-2 font-mono text-sm font-medium text-text-secondary transition-colors hover:text-signal-primary focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-signal-primary"
        >{t('navbar.blog')}</a
      >
      <a
        href="/documents/resume.pdf"
        target="_blank"
        rel="noopener noreferrer"
        class="border-signal-primary/50 hover:bg-signal-primary/10 ml-1 rounded-lg border px-4 py-2 font-mono text-sm font-medium text-signal-primary transition-all hover:border-signal-primary hover:shadow-[0_0_12px_rgba(0,179,89,0.25)] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-signal-primary"
        >{t('navbar.resume')}</a
      >

      <button
        id="language-switcher-desktop"
        aria-label="Change language"
        class="ml-3 flex items-center gap-1 rounded-lg px-3 py-2 font-mono text-sm text-text-secondary transition-colors hover:text-text-primary focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-signal-primary"
      >
        <span aria-hidden="true" class="text-text-secondary/60 select-none">//</span>
        <span class={lang === 'en' ? 'text-text-primary' : ''}>EN</span>
        <span aria-hidden="true" class="text-text-secondary/60 select-none">|</span>
        <span class={lang === 'es' ? 'text-text-primary' : ''}>ES</span>
      </button>
    </div>
  </div>

  <!-- Mobile Menu (Dropdown) -->
  <div
    id="mobile-menu"
    class="bg-surface-primary/90 hidden w-full border-t border-border backdrop-blur-xl md:hidden"
  >
    <div class="flex animate-menu-slide-down flex-col px-6 py-4">
      <a
        href={`/${lang}/blog/`}
        class="block rounded-lg px-4 py-3 text-center font-mono text-sm font-medium text-text-secondary transition-colors hover:bg-surface-secondary hover:text-text-primary"
        >{t('navbar.blog')}</a
      >
      <a
        href="/documents/resume.pdf"
        target="_blank"
        rel="noopener noreferrer"
        class="border-signal-primary/50 hover:bg-signal-primary/10 mt-2 block rounded-lg border px-4 py-3 text-center font-mono text-sm font-medium text-signal-primary transition-all"
        >{t('navbar.resume')}</a
      >
      <button
        id="language-switcher-mobile"
        aria-label="Change language"
        class="mt-2 flex items-center justify-center gap-1 rounded-lg px-4 py-3 font-mono text-sm text-text-secondary transition-colors hover:bg-surface-secondary hover:text-text-primary"
      >
        <span aria-hidden="true" class="text-text-secondary/60 select-none">//</span>
        <span class={lang === 'en' ? 'text-text-primary' : ''}>EN</span>
        <span aria-hidden="true" class="text-text-secondary/60 select-none">|</span>
        <span class={lang === 'es' ? 'text-text-primary' : ''}>ES</span>
      </button>
    </div>
  </div>
</nav>

<style>
  #navbar::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--color-signal-primary), transparent);
    background-size: 200% 100%;
    animation: shimmer 8s ease-in-out infinite;
  }

  @keyframes shimmer {
    0% {
      background-position: -200% 0;
    }
    100% {
      background-position: 200% 0;
    }
  }

  .navbar-scrolled {
    background: var(--color-surface-primary);
    box-shadow: 0 0 20px rgba(0, 0, 0, 0.06);
  }

  .logo-cursor-hidden {
    opacity: 0;
  }

  .logo-cursor-visible {
    animation: blink 1s step-end infinite;
  }

  @keyframes blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const menuToggle = document.getElementById('menu-toggle');
    const mobileMenu = document.getElementById('mobile-menu');
    const navbar = document.getElementById('navbar');

    // Function to toggle the menu
    const toggleMenu = () => {
      const isExpanded = menuToggle?.getAttribute('aria-expanded') === 'true';
      menuToggle?.setAttribute('aria-expanded', String(!isExpanded));
      mobileMenu?.classList.toggle('hidden');
      document.body.classList.toggle('overflow-hidden');
    };

    // Toggle menu on button click
    menuToggle?.addEventListener('click', event => {
      event.stopPropagation();
      toggleMenu();
    });

    // Close menu when a link is clicked
    mobileMenu?.addEventListener('click', event => {
      if ((event.target as HTMLElement).tagName === 'A') {
        toggleMenu();
      }
    });

    // Close menu when clicking outside
    document.addEventListener('click', event => {
      const isClickInside = navbar?.contains(event.target as Node);
      if (!isClickInside && menuToggle?.getAttribute('aria-expanded') === 'true') {
        toggleMenu();
      }
    });

    // Close menu on 'Escape' key press
    document.addEventListener('keydown', event => {
      if (event.key === 'Escape' && menuToggle?.getAttribute('aria-expanded') === 'true') {
        toggleMenu();
      }
    });

    // Scroll listener: add scrolled class for enhanced navbar styling
    window.addEventListener(
      'scroll',
      () => {
        if (window.scrollY > 20) {
          navbar?.classList.add('navbar-scrolled');
        } else {
          navbar?.classList.remove('navbar-scrolled');
        }
      },
      { passive: true }
    );

    // Language switcher logic
    const handleLanguageSwitch = () => {
      const currentPath = window.location.pathname;
      const pathSegments = currentPath.split('/').filter(segment => segment);

      let currentLocale = 'en';
      if (pathSegments.length > 0 && ['en', 'es'].includes(pathSegments[0])) {
        currentLocale = pathSegments.shift() || 'en';
      }

      const newLocale = currentLocale === 'en' ? 'es' : 'en';
      const newPath = `/${newLocale}/${pathSegments.join('/')}`;

      window.location.pathname = newPath.endsWith('/')
        ? newPath.slice(0, -1)
        : newPath || `/${newLocale}`;
    };

    document
      .getElementById('language-switcher-desktop')
      ?.addEventListener('click', handleLanguageSwitch);
    document
      .getElementById('language-switcher-mobile')
      ?.addEventListener('click', handleLanguageSwitch);

    // Logo typing animation
    const logoTyped = document.getElementById('logo-typed');
    const logoCursor = document.getElementById('logo-cursor');

    if (logoTyped && logoCursor) {
      const segments: { text: string; className: string }[] = [
        { text: '> ', className: 'select-none text-signal-primary' },
        { text: 'juan', className: 'font-semibold text-text-primary' },
        { text: '.', className: 'select-none text-text-secondary' },
        { text: 'almeida', className: 'font-semibold text-signal-primary' },
      ];

      // Clear any previous content and show cursor blinking during typing
      logoTyped.textContent = '';
      logoCursor.classList.remove('logo-cursor-hidden');
      logoCursor.classList.add('logo-cursor-visible');

      let segmentIndex = 0;
      let charIndex = 0;
      let currentSpan: HTMLSpanElement | null = null;

      const typeNext = () => {
        if (segmentIndex >= segments.length) return;

        const segment = segments[segmentIndex];

        if (charIndex === 0) {
          currentSpan = document.createElement('span');
          currentSpan.className = segment.className;
          logoTyped.appendChild(currentSpan);
        }

        if (currentSpan && charIndex < segment.text.length) {
          currentSpan.textContent += segment.text[charIndex];
          charIndex++;
          setTimeout(typeNext, 80);
        } else {
          segmentIndex++;
          charIndex = 0;
          if (segmentIndex < segments.length) {
            setTimeout(typeNext, 80);
          }
        }
      };

      setTimeout(typeNext, 300);
    }
  });
</script>
