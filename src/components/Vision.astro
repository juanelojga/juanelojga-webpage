---
import { useTranslations } from '../utils/translate';

const t = useTranslations(Astro);

interface VisionCard {
  label: string;
  icon: string;
  title: string;
  description: string;
}

const cards = t('vision.cards') as unknown as VisionCard[];
---

<section id="vision" class="fade-section relative overflow-hidden bg-slate-900 px-6 py-20 lg:py-28">
  <!-- Dot-grid background texture -->
  <div
    class="pointer-events-none absolute inset-0"
    style="background-image: radial-gradient(circle, rgba(19,127,236,0.06) 1px, transparent 1px); background-size: 28px 28px;"
  >
  </div>

  <div class="relative mx-auto max-w-6xl">
    <p class="mb-3 font-mono text-xs uppercase tracking-[0.2em] text-primary">
      {t('vision.eyebrow')}
    </p>
    <h2 class="mb-2 text-4xl font-extrabold text-white sm:text-5xl">{t('vision.title')}</h2>
    <div class="mb-16 h-1 w-16 rounded-full bg-primary"></div>

    <div class="flex flex-col divide-y divide-slate-800">
      {
        cards.map((card, i) => (
          <div
            class="vision-row group relative flex flex-col gap-6 py-10 pl-6 md:flex-row md:items-center md:gap-12 md:py-12"
            style={`--i: ${i}`}
          >
            <div class="absolute left-0 top-0 h-0 w-0.5 bg-primary transition-[height] duration-500 group-hover:h-full" />

            <span class="shrink-0 font-mono text-6xl font-black leading-none text-slate-700 transition-colors duration-300 group-hover:text-primary/40 md:w-24 md:text-7xl">
              {card.label}
            </span>

            <div class="flex shrink-0 items-center gap-4 md:w-56">
              <div class="flex size-12 items-center justify-center rounded-xl bg-primary/10 transition-all duration-300 group-hover:bg-primary/20 group-hover:shadow-[0_0_20px_rgba(19,127,236,0.25)]">
                <span class="material-symbols-outlined text-2xl text-primary">{card.icon}</span>
              </div>
              <h3 class="text-lg font-bold text-white">{card.title}</h3>
            </div>

            <div class="hidden h-px flex-1 bg-slate-800 md:block" />

            <p class="flex-1 text-sm leading-relaxed text-slate-400 md:max-w-md">
              {card.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .vision-row {
    opacity: 0;
    transform: translateX(-1.5rem);
  }

  .vision-row.visible {
    opacity: 1;
    transform: translateX(0);
    transition:
      opacity 0.55s ease-out calc(var(--i) * 0.15s),
      transform 0.55s ease-out calc(var(--i) * 0.15s);
  }

  @media (prefers-reduced-motion: reduce) {
    .vision-row {
      opacity: 1;
      transform: none;
    }
  }
</style>

<script is:inline>
  const observer = new IntersectionObserver(
    entries => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    },
    { threshold: 0.2 }
  );

  document.querySelectorAll('.vision-row').forEach(el => observer.observe(el));
</script>
