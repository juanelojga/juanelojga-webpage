---
import ProjectCard from './ProjectCard.astro';
import projects from '../content/projects.json';
import { useTranslations } from '../utils/translate';

interface Props {
  title: string;
  lang: string;
}

const { title, lang } = Astro.props;
const t = useTranslations(Astro);
const featured = projects.slice(0, 3);
---

<section id="projects" class="bg-background-light px-6 py-20 lg:py-28">
  <div class="mx-auto max-w-6xl">
    <h2 class="mb-2 text-3xl font-extrabold text-slate-900 sm:text-4xl">{title}</h2>
    <div class="mb-12 h-1 w-16 rounded-full bg-primary"></div>

    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
      {
        featured.map(project => (
          <ProjectCard
            title={project.title}
            slug={project.slug}
            description={project.description}
            tags={project.tags}
            image={project.image}
            lang={lang}
            viewCaseStudyLabel={t('projects.viewCaseStudy')}
          />
        ))
      }
    </div>
  </div>
</section>
