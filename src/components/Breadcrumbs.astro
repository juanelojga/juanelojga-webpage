---
interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="mb-8">
  <ol class="flex flex-wrap items-center gap-1 text-sm">
    {
      items.map((item, index) => (
        <li class="flex items-center gap-1">
          {index > 0 && (
            <span class="material-symbols-outlined text-base text-slate-400">chevron_right</span>
          )}
          {item.href && index < items.length - 1 ? (
            <a href={item.href} class="text-slate-500 transition hover:text-primary">
              {item.label}
            </a>
          ) : (
            <span class="font-semibold text-primary">{item.label}</span>
          )}
        </li>
      ))
    }
  </ol>
</nav>
