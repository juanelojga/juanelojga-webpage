<!-- SVG Software Architecture Background -->
<svg
  class="pointer-events-none absolute inset-0 hidden size-full lg:block"
  viewBox="0 0 1200 800"
  preserveAspectRatio="xMidYMid slice"
  aria-hidden="true"
>
  <defs>
    <radialGradient id="node-glow">
      <stop offset="0%" stop-color="var(--color-accent, #22d3ee)" stop-opacity="0.6"></stop>
      <stop offset="100%" stop-color="var(--color-accent, #22d3ee)" stop-opacity="0"></stop>
    </radialGradient>
  </defs>

  <!-- Architecture boxes (microservices / modules) -->
  <rect x="80" y="120" width="100" height="50" rx="4" class="arch-box float-slow"></rect>
  <rect x="320" y="80" width="110" height="50" rx="4" class="arch-box float-medium"></rect>
  <rect x="580" y="140" width="100" height="50" rx="4" class="arch-box float-slow"></rect>
  <rect x="840" y="90" width="120" height="50" rx="4" class="arch-box float-medium"></rect>
  <rect x="1020" y="160" width="100" height="50" rx="4" class="arch-box float-slow"></rect>
  <rect x="200" y="420" width="110" height="50" rx="4" class="arch-box float-medium"></rect>
  <rect x="500" y="500" width="100" height="50" rx="4" class="arch-box float-slow"></rect>
  <rect x="780" y="560" width="110" height="50" rx="4" class="arch-box float-medium"></rect>
  <rect x="1000" y="480" width="100" height="50" rx="4" class="arch-box float-slow"></rect>

  <!-- Architecture labels inside boxes -->
  <text x="130" y="150" class="arch-label float-slow">API</text>
  <text x="375" y="110" class="arch-label float-medium">Gateway</text>
  <text x="630" y="170" class="arch-label float-slow">Auth</text>
  <text x="900" y="120" class="arch-label float-medium">Queue</text>
  <text x="1070" y="190" class="arch-label float-slow">Cache</text>
  <text x="255" y="450" class="arch-label float-medium">DB</text>
  <text x="550" y="530" class="arch-label float-slow">Worker</text>
  <text x="835" y="590" class="arch-label float-medium">Logger</text>
  <text x="1050" y="510" class="arch-label float-slow">Store</text>

  <!-- Connection lines between architecture boxes -->
  <path d="M180,145 L320,105" class="arch-line dash-flow" pathLength="1"></path>
  <path d="M430,105 L580,165" class="arch-line dash-flow flow-delay-1" pathLength="1"></path>
  <path d="M680,165 L840,115" class="arch-line dash-flow flow-delay-2" pathLength="1"></path>
  <path d="M960,115 L1020,185" class="arch-line dash-flow flow-delay-3" pathLength="1"></path>
  <path d="M310,445 L500,525" class="arch-line dash-flow flow-delay-1" pathLength="1"></path>
  <path d="M600,525 L780,585" class="arch-line dash-flow flow-delay-2" pathLength="1"></path>
  <path d="M890,585 L1000,505" class="arch-line dash-flow flow-delay-3" pathLength="1"></path>
  <path d="M375,130 L255,420" class="arch-line dash-flow flow-delay-2" pathLength="1"></path>
  <path d="M630,190 L550,500" class="arch-line dash-flow flow-delay-3" pathLength="1"></path>
  <path d="M900,140 L835,560" class="arch-line dash-flow" pathLength="1"></path>

  <!-- Data flow particles along architecture paths -->
  <circle r="3" class="data-pulse">
    <animateMotion
      dur="3.5s"
      repeatCount="indefinite"
      path="M180,145 L375,105 L630,165 L900,115 L1070,185"></animateMotion>
  </circle>
  <circle r="2.5" class="data-pulse pulse-delay-1">
    <animateMotion dur="4s" repeatCount="indefinite" path="M255,445 L550,525 L835,585 L1050,505"
    ></animateMotion>
  </circle>
  <circle r="2" class="data-pulse pulse-delay-2">
    <animateMotion dur="5s" repeatCount="indefinite" path="M375,130 L255,445 L550,525"
    ></animateMotion>
  </circle>

  <!-- Terminal / console text lines (floating code snippets) -->
  <text x="60" y="280" class="terminal-text term-line-1">$ docker compose up -d</text>
  <text x="60" y="300" class="terminal-text term-line-2">✓ Container api-gateway started</text>
  <text x="60" y="320" class="terminal-text term-line-3">✓ Container auth-service started</text>

  <text x="720" y="350" class="terminal-text term-line-2">$ git push origin main</text>
  <text x="720" y="370" class="terminal-text term-line-3">→ Deploy triggered</text>

  <text x="400" y="680" class="terminal-text term-line-1">$ npm run build</text>
  <text x="400" y="700" class="terminal-text term-line-3">✓ Build completed in 2.4s</text>

  <text x="900" y="680" class="terminal-text term-line-2">$ kubectl get pods</text>
  <text x="900" y="700" class="terminal-text term-line-1">Running 3/3 replicas</text>

  <!-- Floating code symbols -->
  <text x="150" y="600" class="code-symbol float-slow">{}</text>
  <text x="480" y="260" class="code-symbol float-medium">&lt;/&gt;</text>
  <text x="750" y="460" class="code-symbol float-slow">[ ]</text>
  <text x="1080" y="350" class="code-symbol float-medium">( )</text>
  <text x="300" y="350" class="code-symbol float-slow">=&gt;</text>
  <text x="950" y="250" class="code-symbol float-medium">/**</text>

  <!-- Blinking cursor indicators -->
  <rect x="60" y="335" width="8" height="14" class="cursor-blink"></rect>
  <rect x="720" y="385" width="8" height="14" class="cursor-blink blink-delay-1"></rect>
</svg>

<style>
  svg {
    --color-accent: #4ade80; /* green-400, matches project palette */
  }

  /* Architecture box styles */
  .arch-box {
    fill: none;
    stroke: var(--color-accent, #4ade80);
    stroke-width: 1.2;
    opacity: 0.25;
  }

  .arch-label {
    font-family: ui-monospace, 'Cascadia Code', 'Source Code Pro', Menlo, Consolas, monospace;
    font-size: 11px;
    fill: var(--color-accent, #4ade80);
    opacity: 0.4;
    text-anchor: middle;
    dominant-baseline: central;
  }

  .arch-line {
    stroke: var(--color-accent, #4ade80);
    stroke-width: 1;
    fill: none;
    opacity: 0.2;
  }

  /* Flowing dash animation on lines */
  .dash-flow {
    stroke-dasharray: 0.08 0.06;
    animation: dash-scroll 4s linear infinite;
  }

  .flow-delay-1 {
    animation-delay: -1s;
  }

  .flow-delay-2 {
    animation-delay: -2s;
  }

  .flow-delay-3 {
    animation-delay: -3s;
  }

  @keyframes dash-scroll {
    to {
      stroke-dashoffset: -1;
    }
  }

  /* Traveling data pulse particles */
  .data-pulse {
    fill: var(--color-accent, #4ade80);
    opacity: 0.6;
    filter: url(#node-glow);
  }

  .pulse-delay-1 {
    opacity: 0.5;
  }

  .pulse-delay-2 {
    opacity: 0.45;
  }

  /* Terminal text lines */
  .terminal-text {
    font-family: ui-monospace, 'Cascadia Code', 'Source Code Pro', Menlo, Consolas, monospace;
    font-size: 11px;
    fill: var(--color-accent, #4ade80);
    opacity: 0;
    animation: term-fade-in 1s ease-out forwards;
  }

  .term-line-1 {
    animation-delay: 0.5s;
  }

  .term-line-2 {
    animation-delay: 1.2s;
  }

  .term-line-3 {
    animation-delay: 1.9s;
  }

  @keyframes term-fade-in {
    from {
      opacity: 0;
    }
    to {
      opacity: 0.25;
    }
  }

  /* Floating code symbols */
  .code-symbol {
    font-family: ui-monospace, 'Cascadia Code', 'Source Code Pro', Menlo, Consolas, monospace;
    font-size: 18px;
    fill: var(--color-accent, #4ade80);
    opacity: 0.15;
  }

  /* Blinking cursor */
  .cursor-blink {
    fill: var(--color-accent, #4ade80);
    opacity: 0.45;
    animation: blink 1s step-end infinite;
  }

  .blink-delay-1 {
    animation-delay: 0.5s;
  }

  @keyframes blink {
    0%,
    100% {
      opacity: 0.45;
    }
    50% {
      opacity: 0;
    }
  }

  /* Floating animations */
  .float-slow {
    animation: float-slow 8s ease-in-out infinite;
  }

  .float-medium {
    animation: float-medium 6s ease-in-out infinite;
  }

  @keyframes float-slow {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-15px);
    }
  }

  @keyframes float-medium {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(10px);
    }
  }

  /* Respect reduced motion preferences */
  @media (prefers-reduced-motion: reduce) {
    .float-slow,
    .float-medium,
    .dash-flow,
    .cursor-blink {
      animation: none;
    }

    .terminal-text {
      animation: none;
      opacity: 0.25;
    }

    .data-pulse,
    .data-pulse > animateMotion {
      display: none;
    }
  }
</style>
