---
interface Props {
  bio: {
    sectionTitle: string;
    narrative: string;
    highlightLabel: string;
  };
}

const { bio } = Astro.props;
const paragraphs = bio.narrative.split('\n').filter(p => p.trim());
---

<section
  id="about"
  aria-labelledby="bio-headline"
  class="bio-chapter flex min-h-screen items-center px-6 py-20 lg:px-12 xl:px-20"
>
  <div class="mx-auto flex w-full max-w-6xl flex-col gap-10 lg:flex-row lg:items-center lg:gap-16">
    <!-- Text column (wider) -->
    <div class="flex flex-1 flex-col justify-center lg:order-1">
      <p class="mb-2 font-mono text-meta text-signal-primary">{bio.highlightLabel}</p>
      <h2 id="bio-headline" class="font-mono text-section text-text-primary">{bio.sectionTitle}</h2>

      <div class="mt-8 space-y-5">
        {
          paragraphs.map(paragraph => (
            <p class="max-w-2xl text-body leading-relaxed text-text-secondary">{paragraph}</p>
          ))
        }
      </div>
    </div>

    <!-- Portrait crop placeholder -->
    <div
      class="relative flex aspect-square w-full items-center justify-center overflow-hidden rounded-xl lg:order-2 lg:w-[280px] lg:shrink-0 xl:w-[320px]"
    >
      <div
        class="absolute inset-0 bg-gradient-to-tl from-surface-tertiary via-surface-secondary to-surface-primary"
      >
      </div>
      <div class="absolute inset-0 opacity-15">
        <div
          class="border-signal-secondary/30 absolute right-0 top-0 size-1/2 rounded-bl-[3rem] border-b border-l"
        >
        </div>
        <div class="bg-signal-warm/50 absolute bottom-6 right-6 size-2.5 rounded-full"></div>
        <div class="bg-signal-primary/40 absolute left-6 top-6 size-2 rounded-full"></div>
      </div>
      <span class="text-text-secondary/50 relative z-10 font-mono text-meta">{'{ detail }'}</span>
    </div>
  </div>
</section>

<style>
  .bio-chapter {
    opacity: 0;
    clip-path: inset(0 100% 0 0);
    transition:
      opacity 0.8s ease-out,
      clip-path 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  :global(.bio-chapter.is-visible) {
    opacity: 1;
    clip-path: inset(0 0 0 0);
  }

  @media (prefers-reduced-motion: reduce) {
    .bio-chapter {
      clip-path: none;
      transform: none;
      transition: opacity 0.15s ease-out;
    }

    :global(.bio-chapter.is-visible) {
      clip-path: none;
    }
  }
</style>

<script is:inline>
  (function () {
    var bio = document.querySelector('.bio-chapter');
    if (!bio) return;

    function check() {
      var rect = bio.getBoundingClientRect();
      if (rect.top < window.innerHeight * 0.85 && rect.bottom > 0) {
        bio.classList.add('is-visible');
        window.removeEventListener('scroll', check);
      }
    }

    window.addEventListener('scroll', check, { passive: true });
    check();
  })();
</script>
