---
interface Props {
  title: string;
  slug: string;
  description: string;
  tags: string[];
  image: string;
  lang: string;
  viewCaseStudyLabel: string;
  featured: boolean;
}

const { title, slug, description, tags, image, lang, viewCaseStudyLabel, featured } = Astro.props;

const primaryTag = tags[0] ?? '';
---

<article
  class:list={[
    'group relative flex h-full flex-col overflow-hidden border-l-[3px] border-slate-200 bg-white',
    'transition-all duration-300',
    'hover:border-l-primary hover:shadow-lg hover:shadow-primary/10',
    'focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/30',
  ]}
>
  <!-- Terminal header bar -->
  <div
    aria-hidden="true"
    class="flex shrink-0 items-center gap-2 border-b border-slate-100 bg-slate-50 px-4 py-2.5"
  >
    <span class="size-2.5 rounded-full bg-red-400"></span>
    <span class="size-2.5 rounded-full bg-yellow-400"></span>
    <span class="size-2.5 rounded-full bg-green-400"></span>
    <span class="ml-auto font-mono text-[10px] uppercase tracking-widest text-slate-400">
      {primaryTag}
    </span>
  </div>

  <!-- Image -->
  <div class:list={['shrink-0 overflow-hidden', featured ? 'aspect-[4/3]' : 'aspect-video']}>
    <img
      src={image}
      alt={title}
      class="size-full object-cover transition-transform duration-500 group-hover:scale-105"
      loading="lazy"
    />
  </div>

  <!-- Card body -->
  <div class="relative flex flex-1 flex-col p-6">
    <h3 class:list={['mb-2 font-bold text-slate-900', featured ? 'text-xl' : 'text-lg']}>
      {title}
    </h3>

    <p class="mb-4 flex-1 text-sm leading-relaxed text-slate-600">{description}</p>

    <!-- Tags -->
    <div class="mb-5 flex flex-wrap gap-2">
      {
        tags.map(tag => (
          <span class="rounded bg-primary/10 px-2.5 py-0.5 font-mono text-[10px] uppercase tracking-wider text-primary">
            {tag}
          </span>
        ))
      }
    </div>

    <!-- CTA link with sliding arrow -->
    <a
      href={`/${lang}/projects/${slug}`}
      class="group/link mt-auto inline-flex items-center gap-1.5 text-sm font-semibold text-primary transition-colors hover:text-primary/80"
    >
      {viewCaseStudyLabel}
      <span class="transition-transform duration-200 group-hover/link:translate-x-1">&rarr;</span>
    </a>
  </div>
</article>

<style>
  @media (prefers-reduced-motion: reduce) {
    article span[aria-hidden='true'] {
      transition: none;
    }
  }
</style>
