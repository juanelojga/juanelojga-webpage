---
import { ViewTransitions } from 'astro:transitions';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import GoogleAnalytics from '../components/GoogleAnalytics.astro';
import { useTranslations } from '../utils/translate';
import '../css/global.css';

interface Props {
  title?: string;
  description?: string;
  canonicalUrl?: string;
  ogImage?: string;
  structuredData?: Record<string, unknown>[];
}

const t = useTranslations(Astro);
const { lang } = Astro.params || { lang: 'en' };
const canonicalBase = 'https://juanelojga.com';
const localePath = lang === 'en' ? '' : `/${lang}`;
const defaultCanonicalUrl = `${canonicalBase}${localePath}/`;

// Build hreflang alternates dynamically from the current page path.
// Strips the locale prefix (e.g. /en/resume/ → /resume/) so alternates
// point to the correct page in each language. For the homepage (/en/ → /),
// this correctly produces /en/ and /es/.
const pagePath = Astro.url.pathname.replace(/^\/(en|es)\//, '/');
const enAlternate = `${canonicalBase}/en${pagePath}`;
const esAlternate = `${canonicalBase}/es${pagePath}`;

const pageTitle = Astro.props.title ?? t('seo.title');
const pageDescription = Astro.props.description ?? t('seo.description');
const pageCanonicalUrl = Astro.props.canonicalUrl ?? defaultCanonicalUrl;
const pageOgImage = Astro.props.ogImage ?? '/og-image.jpg';
const structuredData = Astro.props.structuredData ?? [];

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Juan Almeida',
  jobTitle: t('seo.jobTitle'),
  description: t('seo.description'),
  url: defaultCanonicalUrl,
  sameAs: ['https://www.linkedin.com/in/juan-almeida-03806367', 'https://github.com/juanelojga'],
  knowsAbout: [
    'Artificial Intelligence',
    'Machine Learning',
    'Full-Stack Development',
    'TypeScript',
    'Python',
    'System Design',
    'GraphQL',
    'React',
    'Vue.js',
  ],
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <GoogleAnalytics />
    <meta name="description" content={pageDescription} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="viewport" content="width=device-width" />
    <meta
      name="keywords"
      content="Juan Almeida, Full Stack Engineer, AI Engineer, Software Developer, JavaScript, Python, React, Astro, Django"
    />
    <link rel="canonical" href={pageCanonicalUrl} />
    <link rel="alternate" href={enAlternate} hreflang="en" />
    <link rel="alternate" href={esAlternate} hreflang="es" />
    <link rel="alternate" href={enAlternate} hreflang="x-default" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={`${canonicalBase}${pageOgImage}`} />
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
    {
      structuredData.map(schema => (
        <script type="application/ld+json" set:html={JSON.stringify(schema)} />
      ))
    }

    <link rel="icon" type="image/svg+xml" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0"
    />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta property="og:image" content={`${canonicalBase}${pageOgImage}`} />
    <slot name="head" />
    <ViewTransitions />
  </head>
  <body class="bg-background-light font-display text-slate-900">
    <a href="#main" class="sr-only focus:not-sr-only">Skip to content</a>
    <Navbar />
    <main id="main"><slot /></main>
    <Footer />
  </body>
</html>
