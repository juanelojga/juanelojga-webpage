---
import { ClientRouter } from 'astro:transitions';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import GoogleAnalytics from '../components/GoogleAnalytics.astro';
import { useTranslations } from '../utils/translate';
import '../css/global.css';

interface Props {
  title?: string;
  description?: string;
  canonicalUrl?: string;
  ogImage?: string;
  structuredData?: Record<string, unknown>[];
  variant?: 'homepage' | 'subpage';
}

const t = useTranslations(Astro);
const { lang } = Astro.params || { lang: 'en' };
const canonicalBase = 'https://www.juanelojga.com';
const localePath = lang === 'en' ? '' : `/${lang}`;
const defaultCanonicalUrl = `${canonicalBase}${localePath}/`;

// Build hreflang alternates dynamically from the current page path.
// Strips the locale prefix (e.g. /en/resume/ → /resume/) so alternates
// point to the correct page in each language. For the homepage (/en/ → /),
// this correctly produces /en/ and /es/.
const pagePath = Astro.url.pathname.replace(/^\/(en|es)\//, '/');
const enAlternate = `${canonicalBase}/en${pagePath}`;
const esAlternate = `${canonicalBase}/es${pagePath}`;

const pageTitle = Astro.props.title ?? t('seo.title');
const pageDescription = Astro.props.description ?? t('seo.description');
const pageCanonicalUrl = Astro.props.canonicalUrl ?? defaultCanonicalUrl;
const pageOgImage = Astro.props.ogImage ?? '/og-image.jpg';
const structuredData = Astro.props.structuredData ?? [];

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': `${canonicalBase}/#person`,
  name: 'Juan Almeida',
  givenName: 'Juan',
  familyName: 'Almeida',
  jobTitle: t('seo.jobTitle'),
  description: t('seo.description'),
  url: defaultCanonicalUrl,
  image: `${canonicalBase}/og-image.jpg`,
  sameAs: [
    'https://www.linkedin.com/in/juan-almeida-03806367',
    'https://github.com/juanelojga',
    'https://twitter.com/juanelojga',
  ],
  knowsAbout: [
    'Artificial Intelligence',
    'Machine Learning',
    'Full-Stack Development',
    'TypeScript',
    'Python',
    'System Design',
    'GraphQL',
    'React',
    'Vue.js',
    'Django',
    'LangChain',
    'RAG Pipelines',
    'Node.js',
    'Next.js',
    'Astro',
  ],
  knowsLanguage: [
    { '@type': 'Language', name: 'English', alternateName: 'en' },
    { '@type': 'Language', name: 'Spanish', alternateName: 'es' },
  ],
  hasOccupation: [
    {
      '@type': 'Occupation',
      name: 'Senior Frontend Engineer',
      occupationLocation: { '@type': 'Country', name: 'United States' },
      description:
        'Senior frontend engineering at Upwork, building search platforms handling millions of records.',
    },
    {
      '@type': 'Occupation',
      name: 'Full-Stack Lead & Co-Founder',
      description:
        'Led full-stack development at Narbox, engineering logistics platforms with Django GraphQL and Next.js.',
    },
    {
      '@type': 'Occupation',
      name: 'Freelance Engineer & Consultant',
      description:
        'Independent engineering and consulting across AI systems, voice orchestration, and full-stack applications.',
    },
  ],
  worksFor: [
    {
      '@type': 'Organization',
      name: 'JuaneloJGAC Tech',
      description: 'Freelance engineering and consulting',
    },
  ],
};

const variant = Astro.props.variant ?? 'subpage';
const isHomepage = variant === 'homepage';

const ogLocale = lang === 'es' ? 'es_ES' : 'en_US';
const ogLocaleAlternate = lang === 'es' ? 'en_US' : 'es_ES';

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${canonicalBase}/#website`,
  name: 'Juan Almeida',
  url: canonicalBase,
  inLanguage: lang,
  author: { '@id': `${canonicalBase}/#person` },
};

const profilePageSchema = isHomepage
  ? {
      '@context': 'https://schema.org',
      '@type': 'ProfilePage',
      '@id': `${canonicalBase}/${lang}/#profilepage`,
      mainEntity: { '@id': `${canonicalBase}/#person` },
      dateCreated: '2024-01-01',
      dateModified: '2026-03-31',
    }
  : null;
---

<!doctype html>
<html lang={lang} data-theme="build">
  <head>
    <meta charset="UTF-8" />
    <!-- Inline theme detection — runs before first paint to prevent FOUC -->
    <script is:inline>
      (function () {
        function syncTheme() {
          var t = localStorage.getItem('theme');
          if (t === 'build' || t === 'after-hours') {
            document.documentElement.setAttribute('data-theme', t);
          } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
            document.documentElement.setAttribute('data-theme', 'after-hours');
          }
        }
        syncTheme();
        document.addEventListener('astro:after-swap', syncTheme);
      })();
    </script>
    <GoogleAnalytics />
    <meta name="description" content={pageDescription} />
    <meta name="author" content="Juan Almeida" />
    <meta name="date" content="2026-03-31" />
    <meta name="last-modified" content="2026-03-31" />
    <link rel="author" href="/humans.txt" />
    <meta
      name="robots"
      content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"
    />
    <meta name="theme-color" content="#f5f5f0" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#1a1a1a" media="(prefers-color-scheme: dark)" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={pageCanonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:site_name" content="Juan Almeida" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={ogLocaleAlternate} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={pageTitle} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:site" content="@juanelojga" />
    <meta name="twitter:creator" content="@juanelojga" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta
      name="keywords"
      content="Juan Almeida, Full Stack Engineer, AI Engineer, Software Developer, JavaScript, Python, React, Astro, Django"
    />
    <link rel="canonical" href={pageCanonicalUrl} />
    <link rel="alternate" href={enAlternate} hreflang="en" />
    <link rel="alternate" href={esAlternate} hreflang="es" />
    <link rel="alternate" href={enAlternate} hreflang="x-default" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={`${canonicalBase}${pageOgImage}`} />
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
    {
      profilePageSchema && (
        <script type="application/ld+json" set:html={JSON.stringify(profilePageSchema)} />
      )
    }
    {
      structuredData.map(schema => (
        <script type="application/ld+json" set:html={JSON.stringify(schema)} />
      ))
    }

    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0"
    />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta property="og:image" content={`${canonicalBase}${pageOgImage}`} />
    <slot name="head" />
    <ClientRouter />
  </head>
  <body class="bg-surface-primary font-display text-text-primary">
    <a href="#main" class="sr-only focus:not-sr-only">Skip to content</a>
    {
      isHomepage ? (
        <div class="flex min-h-screen flex-col lg:flex-row">
          <slot name="rail" />
          <main id="main" class="flex-1 lg:order-first">
            <slot />
          </main>
        </div>
      ) : (
        <>
          <Navbar />
          <main id="main">
            <slot />
          </main>
          <Footer />
        </>
      )
    }
  </body>
</html>
