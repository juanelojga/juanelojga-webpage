---
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ResumePreview from '../../components/ResumePreview.astro';
import ResumeSkillsGrid from '../../components/ResumeSkillsGrid.astro';
import LeadCaptureForm from '../../components/LeadCaptureForm';
import skills from '../../content/skills.json';
import { skillCategoryKeyMap } from '../../utils/skills';

export async function getStaticPaths() {
  return [{ params: { lang: 'en' } }, { params: { lang: 'es' } }];
}

const { lang } = Astro.params;
const t = await import(`../../i18n/${lang}.json`).then(m => m.default);
const resume = t.resume;

const skillCategories = skills.map(group => ({
  icon: group.icon,
  label: resume.skillCategories[skillCategoryKeyMap[group.category]] || group.category,
  skills: group.skills,
}));

const canonicalBase = 'https://juanelojga.com';
const canonicalUrl = `${canonicalBase}/${lang}/resume/`;

const webPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: resume.seo.title,
  description: resume.seo.description,
  url: canonicalUrl,
  inLanguage: lang,
  isPartOf: {
    '@type': 'WebSite',
    name: 'Juan Almeida Portfolio',
    url: `${canonicalBase}/`,
  },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: resume.breadcrumb.home,
      item: `${canonicalBase}/${lang}/`,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: resume.breadcrumb.resume,
    },
  ],
};
---

<Layout
  title={resume.seo.title}
  description={resume.seo.description}
  canonicalUrl={canonicalUrl}
  structuredData={[webPageSchema, breadcrumbSchema]}
>
  <Fragment slot="head">
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:url" content={canonicalUrl} />
  </Fragment>

  <div class="bg-background-light">
    <!-- Breadcrumbs -->
    <div class="mx-auto max-w-6xl px-6 pt-8">
      <Breadcrumbs
        items={[
          { label: resume.breadcrumb.home, href: `/${lang}/` },
          { label: resume.breadcrumb.resume },
        ]}
      />
    </div>

    <!-- Page Header -->
    <header class="mx-auto max-w-6xl px-6 pb-12 pt-4">
      <h1 class="text-4xl font-extrabold tracking-tight text-slate-900 md:text-5xl">
        {resume.pageTitle}
      </h1>
      <p class="mt-4 max-w-2xl text-lg leading-relaxed text-slate-600">
        {resume.subtitle}
      </p>
    </header>

    <!-- Resume Preview -->
    <section aria-label={resume.pageTitle} class="mx-auto max-w-6xl px-6 py-12 pb-20">
      <ResumePreview />
    </section>

    <!-- Skills Grid -->
    <ResumeSkillsGrid title={resume.sections.skills} categories={skillCategories} />

    <!-- Lead Capture Form -->
    <section aria-labelledby="lead-capture-heading" class="mx-auto max-w-6xl px-6 pb-20">
      <LeadCaptureForm lang={lang} labels={resume.form} client:visible />
    </section>
  </div>
</Layout>
