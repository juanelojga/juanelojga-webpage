---
import { getImage } from 'astro:assets';
import heroBuildImg from '../../assets/images/hero-build-final.jpg';
import heroAfterHoursImg from '../../assets/images/hero-after-hours-final.jpg';
import Layout from '../../layouts/Layout.astro';
import HomepageShell from '../../components/HomepageShell';
import HeroNarrative from '../../components/HeroNarrative';
import BioChapter from '../../components/BioChapter.astro';
import SkillMatrix from '../../components/SkillMatrix';
import WorkLog from '../../components/WorkLog';
import ContactChapter from '../../components/ContactChapter';
import FeaturedPosts from '../../components/blog/FeaturedPosts';
import { getBlogPostsByLang } from '../../utils/blog';

export async function getStaticPaths() {
  return [{ params: { lang: 'en' } }, { params: { lang: 'es' } }];
}

const { lang } = Astro.params;
const t = await import(`../../i18n/${lang}.json`).then(m => m.default);
const projects = await import('../../content/projects.json').then(m => m.default);

const blogPosts = await getBlogPostsByLang(lang as 'en' | 'es');
const featuredPosts = blogPosts.slice(0, 3).map(post => ({
  title: post.data.title,
  date: post.data.date.toISOString(),
  tags: post.data.tags,
  summary: post.data.summary,
  slug: post.data.slug,
  category: post.data.category,
  readingTime: post.data.readingTime,
}));

const canonicalBase = 'https://www.juanelojga.com';

const buildPortrait = await getImage({ src: heroBuildImg, width: 1140, format: 'webp' });
const afterHoursPortrait = await getImage({ src: heroAfterHoursImg, width: 1140, format: 'webp' });

const shellLabels = {
  todoRail: t.todoRail,
  themeToggle: t.themeToggle,
  localeSwitcher: t.localeSwitcher,
  resumeLabel: t.navbar.resume,
};

const heroLabels = t.heroNarrative;
const skillMatrixLabels = t.skillMatrix;
const workLogLabels = t.workLog;
const featuredPostsLabels = t.featuredPosts;
const contactLabels = t.contact;

// Structured data: ItemList of featured projects
const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Featured Projects by Juan Almeida',
  numberOfItems: projects.filter((p: any) => p.featured).length,
  itemListElement: projects
    .filter((p: any) => p.featured)
    .map((project: any, index: number) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: project.title,
      description: project.description,
      url: `${canonicalBase}/${lang}/case-study/${project.slug}`,
    })),
};

// Structured data: BreadcrumbList for homepage
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: lang === 'es' ? 'Inicio' : 'Home',
      item: `${canonicalBase}/${lang}/`,
    },
  ],
};

// Structured data: Speakable for voice assistants
const speakableSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': `${canonicalBase}/${lang}/#webpage`,
  name: t.seo.title,
  speakable: {
    '@type': 'SpeakableSpecification',
    cssSelector: ['#hero-narrative', '#bio-narrative'],
  },
  isPartOf: { '@id': `${canonicalBase}/#website` },
  about: { '@id': `${canonicalBase}/#person` },
  inLanguage: lang,
};

const homepageStructuredData = [itemListSchema, breadcrumbSchema, speakableSchema];
---

<Layout variant="homepage" structuredData={homepageStructuredData}>
  <!-- Home / Hero -->
  <HeroNarrative
    client:load
    labels={heroLabels}
    lang={lang}
    buildPortraitSrc={buildPortrait.src}
    afterHoursPortraitSrc={afterHoursPortrait.src}
  />

  <!-- About / Bio Chapter -->
  <BioChapter bio={t.bio} />

  <!-- Skills / Skill Matrix -->
  <SkillMatrix client:visible labels={skillMatrixLabels} lang={lang} />

  <!-- Projects / Work Log -->
  <WorkLog client:visible labels={workLogLabels} lang={lang} />

  <!-- Blog / Featured Posts -->
  <FeaturedPosts client:visible labels={featuredPostsLabels} lang={lang} posts={featuredPosts} />

  <!-- Contact / Open Channel -->
  <ContactChapter client:visible labels={contactLabels} />

  <HomepageShell slot="rail" client:load lang={lang} labels={shellLabels} />
</Layout>
