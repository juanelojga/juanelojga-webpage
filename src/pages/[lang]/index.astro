---
import { getImage } from 'astro:assets';
import heroBuildImg from '../../assets/images/hero-build-final.jpg';
import heroAfterHoursImg from '../../assets/images/hero-after-hours-final.jpg';
import Layout from '../../layouts/Layout.astro';
import HomepageShell from '../../components/HomepageShell';
import HeroNarrative from '../../components/HeroNarrative';
import BioChapter from '../../components/BioChapter.astro';
import SkillMatrix from '../../components/SkillMatrix';
import WorkLog from '../../components/WorkLog';
import ContactChapter from '../../components/ContactChapter';

export async function getStaticPaths() {
  return [{ params: { lang: 'en' } }, { params: { lang: 'es' } }];
}

const { lang } = Astro.params;
const t = await import(`../../i18n/${lang}.json`).then(m => m.default);

const buildPortrait = await getImage({ src: heroBuildImg, width: 1140, format: 'webp' });
const afterHoursPortrait = await getImage({ src: heroAfterHoursImg, width: 1140, format: 'webp' });

const shellLabels = {
  todoRail: t.todoRail,
  themeToggle: t.themeToggle,
  localeSwitcher: t.localeSwitcher,
  resumeLabel: t.navbar.resume,
};

const heroLabels = t.heroNarrative;
const skillMatrixLabels = t.skillMatrix;
const workLogLabels = t.workLog;
const contactLabels = t.contact;
---

<Layout title="Juan Almeida | Full Stack & AI Engineer" variant="homepage">
  <!-- Home / Hero -->
  <HeroNarrative
    client:load
    labels={heroLabels}
    lang={lang}
    buildPortraitSrc={buildPortrait.src}
    afterHoursPortraitSrc={afterHoursPortrait.src}
  />

  <!-- About / Bio Chapter -->
  <BioChapter bio={t.bio} />

  <!-- Skills / Skill Matrix -->
  <SkillMatrix client:visible labels={skillMatrixLabels} lang={lang} />

  <!-- Projects / Work Log -->
  <WorkLog client:visible labels={workLogLabels} lang={lang} />

  <!-- Contact / Open Channel -->
  <ContactChapter client:visible labels={contactLabels} />

  <HomepageShell slot="rail" client:load lang={lang} labels={shellLabels} />
</Layout>
